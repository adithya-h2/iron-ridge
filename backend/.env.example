# ===========================================================
# Iron Ridge Intelligent Sales Workflow — Environment Variables
# Copy this file to .env and fill in real values.
# NEVER commit .env to version control.
# ===========================================================

# --- Application ---
APP_NAME="Iron Ridge Intelligent Sales Workflow"
APP_ENV=development          # development | staging | production
APP_VERSION=1.0.0
DEBUG=true
LOG_LEVEL=INFO
# Expose /docs and /openapi.json (set false to hide Swagger in production)
ENABLE_API_DOCS=true

# --- Server ---
HOST=0.0.0.0
PORT=8000

# --- Database (Supabase PostgreSQL) ---
# Render/Railway: use Supabase *Transaction pooler* (IPv4-friendly), not direct db.*:5432
# Dashboard → Settings → Database → Connection string → Transaction pooler → URI
# Example pooler (replace placeholders):
# DATABASE_URL=postgresql+asyncpg://postgres.[PROJECT-REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres
# Local direct (dev only):
# DATABASE_URL=postgresql+asyncpg://postgres:[PASSWORD]@db.[PROJECT-REF].supabase.co:5432/postgres
DATABASE_URL=postgresql+asyncpg://postgres:[YOUR-PASSWORD]@db.[YOUR-PROJECT-REF].supabase.co:5432/postgres
# SSL required for Supabase from cloud hosts (Render/Railway). Set false for local Postgres without TLS.
DATABASE_SSL=true

# --- JWT Authentication ---
SECRET_KEY=change-me-to-a-random-256-bit-secret
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# --- OpenAI ---
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o

# --- Anthropic ---
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-3-5-sonnet-20241022

# --- Active AI Provider (openai | anthropic) ---
AI_PROVIDER=openai

# --- n8n (full published production webhook URL — no path suffix appended) ---
# Example: https://YOUR_ACCOUNT.app.n8n.cloud/webhook/YOUR_WEBHOOK_UUID
N8N_WEBHOOK_BASE_URL=https://YOUR_ACCOUNT.app.n8n.cloud/webhook/YOUR_WEBHOOK_UUID
# Used by consultation service (optional — separate webhook if configured)
N8N_WEBHOOK_URL=

# --- Slack (human-in-the-loop ONLY) ---
SLACK_BOT_TOKEN=xoxb-...
SLACK_SIGNING_SECRET=
SLACK_APPROVAL_CHANNEL=#sales-approvals

# --- Agent / Admin bootstrap ---
AGENT_API_KEY=your-agent-api-key-for-n8n
ADMIN_EMAIL=admin@ironridge.com
ADMIN_PASSWORD=changeme

# --- Redis (optional — leave empty to disable caching) ---
REDIS_URL=redis://localhost:6379/0

# --- CORS (include your Vercel frontend URL in production) ---
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8000,https://YOUR_VERCEL_APP.vercel.app

# --- Supabase (optional — reserved for future direct Supabase client use) ---
SUPABASE_URL=
SUPABASE_KEY=

# --- Frontend URL (optional — used for CORS/links in notifications) ---
NEXT_PUBLIC_FRONTEND_URL=

# --- HTTP Timeouts (seconds) ---
LLM_TIMEOUT_SECONDS=30
N8N_TIMEOUT_SECONDS=15
EXTERNAL_HTTP_TIMEOUT_SECONDS=30

# --- Email (optional) ---
EMAIL_ENABLED=false
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
EMAIL_FROM=noreply@ironridge.com

# --- Feature Flags ---
FEATURE_PDF_EXPORT=true
FEATURE_DASHBOARD=true
FEATURE_RETRY_TRACKING=true
FEATURE_EMAIL_NOTIFICATIONS=false
# Set true after configuring N8N_WEBHOOK_BASE_URL and manual n8n skip-Create-Deal change
FEATURE_N8N_PUBLISH=false

# --- PDF Branding ---
PDF_COMPANY_NAME=Iron Ridge Fire Apparatus
PDF_COMPANY_ADDRESS=123 Fire Station Road, Denver, CO

# --- Metrics ---
METRICS_ENABLED=true
